<Window x:Class="PersonalAssistant.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="720" Width="520"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResizeWithGrip" MinHeight="600" MinWidth="440">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚙ 设置" FontSize="20" FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <RadioButton x:Name="TabGeneral" Content="通用" IsChecked="True"
                         GroupName="SettingsTab" Click="SettingsTab_Click" Tag="0"
                         Style="{StaticResource TabRadioStyle}" Margin="0,0,4,0"/>
            <RadioButton x:Name="TabSchedule" Content="工作时间"
                         GroupName="SettingsTab" Click="SettingsTab_Click" Tag="1"
                         Style="{StaticResource TabRadioStyle}" Margin="4,0"/>
        </StackPanel>

        <!-- General Page -->
        <Border x:Name="PageGeneral" Grid.Row="2" Background="White" CornerRadius="14" Padding="24"
                SnapsToDevicePixels="True">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="专注时长（分钟）" VerticalAlignment="Center" Margin="0,0,16,14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding FocusMinutes}" Margin="0,0,0,14" Width="100" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="休息时长（分钟）" VerticalAlignment="Center" Margin="0,0,16,14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding BreakMinutes}" Margin="0,0,0,14" Width="100" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="喝水提醒（分钟）" VerticalAlignment="Center" Margin="0,0,16,14"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WaterReminderMinutes}" Margin="0,0,0,14" Width="100" HorizontalAlignment="Left"/>

                        <CheckBox Grid.Row="3" Grid.ColumnSpan="2" Content="启用声音提醒" IsChecked="{Binding EnableSound}" Margin="0,0,0,14"/>
                        <CheckBox Grid.Row="4" Grid.ColumnSpan="2" Content="启用喝水提醒" IsChecked="{Binding EnableWaterReminder}" Margin="0,0,0,14"/>
                        <CheckBox Grid.Row="5" Grid.ColumnSpan="2" Content="开机自启动" IsChecked="{Binding AutoStartWithWindows}" Margin="0,0,0,14"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="悬浮窗透明度" VerticalAlignment="Center" Margin="0,0,16,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Slider Grid.Row="6" Grid.Column="1" Minimum="0.3" Maximum="1.0"
                                Value="{Binding FloatWindowOpacity}" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Schedule Page -->
        <Border x:Name="PageSchedule" Grid.Row="2" Background="White" CornerRadius="14" Padding="24"
                SnapsToDevicePixels="True" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <StackPanel>
                    <CheckBox Content="启用排班模式（按时间段自动运行）"
                              IsChecked="{Binding Schedule.ScheduledMode}" Margin="0,0,0,16"
                              FontWeight="SemiBold"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="专注" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding Schedule.FocusMinutes}" Width="56" VerticalContentAlignment="Center" Padding="6,4" Margin="0,0,6,0"/>
                        <TextBlock Text="分钟  休息" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox Text="{Binding Schedule.BreakMinutes}" Width="56" VerticalContentAlignment="Center" Padding="6,4" Margin="0,0,6,0"/>
                        <TextBlock Text="分钟" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="工作时段" FontWeight="SemiBold" FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <StackPanel x:Name="SlotsPanel"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,16">
                        <Button Content="+ 添加时段" Height="32" Click="AddSlot_Click" Margin="0,0,8,0"/>
                        <Button Content="删除末尾" Height="32" Click="RemoveSlot_Click"/>
                    </StackPanel>

                    <Border Background="#F0F7FF" CornerRadius="10" Padding="16,12">
                        <StackPanel>
                            <TextBlock Text="今日预览" FontWeight="SemiBold" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="PreviewText" Text="" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="应用" Width="90" Height="36" Margin="0,0,12,0"
                    Style="{StaticResource PrimaryButton}"
                    Click="ApplyButton_Click"/>
            <Button Content="保存" Width="90" Height="36" Margin="0,0,12,0"
                    Style="{StaticResource PrimaryButton}"
                    Click="SaveButton_Click"/>
            <Button Content="取消" Width="90" Height="36"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
