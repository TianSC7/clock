<Window x:Class="PersonalAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PersonalAssistant"
        Title="PersonalAssistant" Height="560" Width="720"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        Closing="Window_Closing">
    <Window.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <local:NullToCollapsingConverter x:Key="NullToCollapsing"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#EEE" BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource PrimaryBrush}"
                        Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="PersonalAssistant" FontSize="16" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Border Margin="16,0,0,0" Background="{StaticResource BorderBrush}"
                        Width="1" Height="18" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" x:Name="TabButtons">
                    <RadioButton x:Name="TabPomodoro" Content="🍅 番茄钟" IsChecked="True"
                                 GroupName="MainTab" Click="Tab_Click" Tag="0"
                                 Style="{StaticResource TabRadioStyle}" Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabTodo" Content="✅ 待办事项"
                                 GroupName="MainTab" Click="Tab_Click" Tag="1"
                                 Style="{StaticResource TabRadioStyle}" Margin="4,0"/>
                    <RadioButton x:Name="TabLog" Content="📝 日志"
                                 GroupName="MainTab" Click="Tab_Click" Tag="2"
                                 Style="{StaticResource TabRadioStyle}" Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" x:Name="ContentArea" Margin="0">
            <!-- 番茄钟 Page -->
            <Grid x:Name="PagePomodoro" Margin="24,24,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="32"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <Border Background="#E8F5E9" CornerRadius="12" Padding="12,6">
                                <TextBlock Text="{Binding Pomodoro.PhaseDisplay}" FontSize="15" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Scheduled mode status -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0"
                                    Visibility="{Binding Pomodoro.IsScheduledMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Pomodoro.ScheduleStatus}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text=" · " Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"
                                       Visibility="{Binding Pomodoro.ScheduleDetail, Converter={StaticResource NullToCollapsing}}"/>
                            <TextBlock Text="{Binding Pomodoro.ScheduleDetail}" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8,0,8">
                            <Ellipse Width="180" Height="180" Stroke="{StaticResource BorderBrush}"
                                     StrokeThickness="3" Fill="White"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Pomodoro.TimeDisplay}"
                                           FontSize="50" FontWeight="Bold" FontFamily="{StaticResource MonoFont}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Free mode buttons -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8"
                                    Visibility="{Binding Pomodoro.IsScheduledMode, Converter={StaticResource InvBoolToVis}}">
                            <Button Content="▶ 开始" Height="38" MinWidth="90"
                                    Style="{StaticResource PrimaryButton}" FontSize="14"
                                    Command="{Binding Pomodoro.StartCommand}" Margin="4,0"/>
                            <Button Content="⏸ 暂停" Height="38" MinWidth="80"
                                    Command="{Binding Pomodoro.PauseCommand}" Margin="4,0"/>
                            <Button Content="▶ 继续" Height="38" MinWidth="80"
                                    Command="{Binding Pomodoro.ResumeCommand}" Margin="4,0"/>
                            <Button Content="⏭ 跳过" Height="38" MinWidth="80"
                                    Command="{Binding Pomodoro.SkipCommand}" Margin="4,0"/>
                            <Button Content="⟲ 重置" Height="38" MinWidth="80"
                                    Command="{Binding Pomodoro.ResetCommand}" Margin="4,0"/>
                        </StackPanel>

                        <!-- Scheduled mode next block info -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8"
                                    Visibility="{Binding Pomodoro.IsScheduledMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding Pomodoro.NextBlockInfo}" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Row="4" Background="#F8F9FA" CornerRadius="10" Padding="16,10"
                                HorizontalAlignment="Center" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="今日完成"/>
                                </TextBlock>
                                <TextBlock Text="{Binding Pomodoro.CompletedCount, Mode=OneWay}"
                                           FontWeight="Bold" FontSize="20" Foreground="{StaticResource PrimaryBrush}"
                                           Margin="8,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="/"/>
                                    <Run Text="{Binding Pomodoro.TotalFocusBlocks, Mode=OneWay}"/>
                                    <Run Text="个番茄钟"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 待办事项 Page -->
            <Grid x:Name="PageTodo" Visibility="Collapsed" Margin="24,24,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Todo.NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" VerticalContentAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <ComboBox Grid.Column="1" SelectedValue="{Binding Todo.NewPriority}" SelectedValuePath="Tag"
                                  Width="70" Height="36" Margin="0,0,8,0" VerticalContentAlignment="Center">
                            <ComboBoxItem Tag="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="低" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="2">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#2196F3" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="中" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="3">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Fill="#E74C3C" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="高" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                        <Button Grid.Column="2" Content="+ 添加" Height="36" MinWidth="80"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding Todo.AddCommand}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="4"
                        SnapsToDevicePixels="True">
                    <ListBox ItemsSource="{Binding Todo.Todos}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="6,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                              Click="TodoCheckBox_Clicked"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center"
                                               Margin="0,0,10,0" FontSize="13"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Border Grid.Column="2" Background="#FFF8E1" CornerRadius="6" Padding="8,3" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding DueDate}" Foreground="#F57F17"
                                                   FontSize="11" VerticalAlignment="Center"/>
                                    </Border>
                                    <Button Grid.Column="3" Content="删除" FontSize="11" Padding="8,2"
                                            Style="{StaticResource DangerButton}"
                                            Command="{Binding DataContext.Todo.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Expander Grid.Row="2" Header="已完成" Margin="0,12,0,0">
                    <Border Background="White" CornerRadius="12" Padding="4" Margin="0,6,0,0"
                            SnapsToDevicePixels="True">
                        <ListBox ItemsSource="{Binding Todo.CompletedTodos}" MaxHeight="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="6,4">
                                        <CheckBox IsChecked="{Binding IsDone}" IsEnabled="False" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="10,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextDecorations="Strikethrough" FontSize="13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Expander>
            </Grid>

            <!-- 日志 Page -->
            <Grid x:Name="PageLog" Visibility="Collapsed" Margin="24,24,24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,12"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Log.NewContent, UpdateSourceTrigger=PropertyChanged}"
                                 Height="36" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="记录" Height="36" MinWidth="70"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding Log.AddCommand}"/>
                        <Button Grid.Column="2" Content="导出" Height="36" MinWidth="70"
                                Margin="8,0,0,0" Command="{Binding Log.ExportCommand}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="4"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="16,10" Margin="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="📅"/>
                                    <Run Text="{Binding Log.SelectedDate, Mode=OneWay}" FontWeight="SemiBold"
                                         Foreground="{StaticResource TextPrimaryBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ListBox Grid.Row="1" ItemsSource="{Binding Log.TodayLogs}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Background="#E8F5E9" CornerRadius="6" Padding="8,3" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Time}" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{StaticResource SuccessBrush}"/>
                                        </Border>
                                        <Border Grid.Column="1" Background="#F0F0F0" CornerRadius="6" Padding="8,3" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Source}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Content}" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
